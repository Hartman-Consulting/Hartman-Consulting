@page
@model ReachForTheSky.Pages.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<h2>Create Account</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div>
        <label asp-for="Input.Name"></label>
        <input asp-for="Input.Name" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Input.Email"></label>
        <input asp-for="Input.Email" />
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Input.Password"></label>
        <input asp-for="Input.Password" type="password" />
        <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Input.Phone"></label>
        <input asp-for="Input.Phone" />
    </div>

    <div>
        <label asp-for="Input.AccountType"></label>
        <select asp-for="Input.AccountType">
            <option value="Personal">Personal</option>
            <option value="Organization">Organization</option>
        </select>
    </div>

    <div>
        <label asp-for="Input.TravelRadius"></label>
        <input asp-for="Input.TravelRadius" type="number" />
    </div>

    <div>
        <label asp-for="Input.ADAPreferences"></label>
        <input asp-for="Input.ADAPreferences" />
    </div>

    <button type="submit">Register</button>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <p>@Model.StatusMessage</p>
    }
</form>