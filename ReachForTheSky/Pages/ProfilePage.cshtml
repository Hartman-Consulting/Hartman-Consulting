@page
@model ProfilePageModel

<h2>User Profile</h2>

<div class="profile-container">

    <form method="post">
        
        <label>Name:</label>
        <input asp-for="User.Name" class="form-control" />

        <label>Email:</label>
        <input asp-for="User.Email" class="form-control" />

        <label>Phone Number:</label>
        <input asp-for="User.PhoneNumber" class="form-control" />

        <label>ADA Preferences:</label>
        <textarea asp-for="User.ADAPreferences" class="form-control"></textarea>

        <label>Rating:</label>
        <input asp-for="User.Rating" class="form-control" readonly />

        <label>Credit Balance (Hours):</label>
        <input asp-for="User.CreditBalance" class="form-control" readonly />

        <label>Travel Radius (miles):</label>
        <input asp-for="User.TravelRadius" class="form-control" />

        <br />

        <button type="submit" class="btn btn-primary">Save Profile</button>

    </form>

</div>
